"""
Production-grade unit tests for data validators
Senior MLOps Engineer Level
"""

import pytest
import pandas as pd
import numpy as np
import json
import tempfile
import os
from unittest.mock import Mock, patch, MagicMock
from hypothesis import given, strategies as st
from src.data.validators import (
    DataTypeValidator,
    RangeValidator,
    SchemaValidator,
    SalesDataValidator,
    DemandForecastValidator,
    DataValidator,
    ValidationResult,
    validate_sales_data,
    validate_forecast,
)


# ============================================================
# FIXTURES - Reusable test data
# ============================================================

@pytest.fixture
def valid_sales_df():
    """Create a valid sales DataFrame"""
    return pd.DataFrame({
        "product_id": [1, 2, 3, 4, 5],
        "sales": [100, 200, 150, 300, 250],
        "date": ["2024-01-01", "2024-01-02", "2024-01-03", "2024-01-04", "2024-01-05"]
    })

@pytest.fixture
def valid_forecast_df():
    """Create a valid forecast DataFrame"""
    return pd.DataFrame({
        "product_id": [1, 2, 3, 4, 5],
        "forecast_date": ["2024-02-01", "2024-02-02", "2024-02-03", "2024-02-04", "2024-02-05"],
        "predicted_demand": [80, 90, 85, 95, 88]
    })

@pytest.fixture
def schema_validator():
    """Create a schema validator with test schema"""
    schema = {
        "required": ["name", "age", "email"],
        "types": {"name": str, "age": int, "email": str}
    }
    return SchemaValidator({"schema": schema})


# ============================================================
# TEST: DataTypeValidator
# ============================================================

class TestDataTypeValidator:
    """Test DataTypeValidator with various data types"""
    
    @pytest.mark.parametrize("value,expected_type,should_pass", [
        ("test", str, True),
        (123, str, False),
        (123, int, True),
        ("123", int, False),
        (3.14, float, True),
        (3.14, int, False),
        (True, bool, True),
        (1, bool, False),
        ([1, 2, 3], list, True),
        ((1, 2, 3), list, False),
        ({"key": "value"}, dict, True),
        ({"key": "value"}, list, False),
    ])
    def test_data_type_validation(self, value, expected_type, should_pass):
        """Test validation with various data types using parametrization"""
        validator = DataTypeValidator({"expected_type": expected_type})
        result = validator.validate(value)
        
        if should_pass:
            assert result.is_valid is True
            assert len(result.errors) == 0
        else:
            assert result.is_valid is False
            assert len(result.errors) > 0
            assert "Expected type" in result.errors[0]

    def test_no_type_defined(self):
        """Test validation when no type is specified"""
        validator = DataTypeValidator({})
        result = validator.validate("anything")
        assert result.is_valid is True
        assert len(result.errors) == 0


# ============================================================
# TEST: RangeValidator
# ============================================================

class TestRangeValidator:
    """Test RangeValidator with boundary values"""
    
    @pytest.mark.parametrize("value,min_val,max_val,should_pass", [
        # Within range
        (50, 0, 100, True),
        (0, 0, 100, True),   # Boundary - inclusive
        (100, 0, 100, True),  # Boundary - inclusive
        # Outside range
        (-10, 0, 100, False),
        (150, 0, 100, False),
        # Only min defined
        (10, 5, None, True),
        (3, 5, None, False),
        # Only max defined
        (10, None, 20, True),
        (25, None, 20, False),
        # No bounds
        (50, None, None, True),
    ])
    def test_range_boundaries(self, value, min_val, max_val, should_pass):
        """Test range validation with boundary values using parametrization"""
        config = {}
        if min_val is not None:
            config["min"] = min_val
        if max_val is not None:
            config["max"] = max_val
        
        validator = RangeValidator(config)
        result = validator.validate(value)
        
        if should_pass:
            assert result.is_valid is True
        else:
            assert result.is_valid is False
            assert len(result.errors) > 0

    def test_non_numeric_data(self):
        """Test range validation with non-numeric data"""
        validator = RangeValidator({"min": 0, "max": 100})
        
        @pytest.mark.parametrize("value", [
            "not a number",
            [1, 2, 3],
            {"key": "value"},
            None,
        ])
        def _test(value):
            result = validator.validate(value)
            assert result.is_valid is False
            assert "non-numeric" in result.errors[0].lower()

    @given(st.integers(min_value=-1000, max_value=1000))
    def test_range_property_based(self, value):
        """Property-based test: Validate that range validator works for all integers"""
        validator = RangeValidator({"min": -500, "max": 500})
        result = validator.validate(value)
        
        if -500 <= value <= 500:
            assert result.is_valid is True
        else:
            assert result.is_valid is False
            assert "less than" in result.errors[0] or "greater than" in result.errors[0]


# ============================================================
# TEST: SchemaValidator
# ============================================================

class TestSchemaValidator:
    """Test SchemaValidator with various schemas"""
    
    def test_valid_schema(self, schema_validator):
        """Test valid data against schema"""
        data = {"name": "Alice", "age": 30, "email": "alice@test.com"}
        result = schema_validator.validate(data)
        assert result.is_valid is True
        assert len(result.errors) == 0

    @pytest.mark.parametrize("data,expected_error", [
        ({"name": "Alice", "age": 30}, "Missing required field: email"),
        ({"name": "Alice", "email": "alice@test.com"}, "Missing required field: age"),
        ({"age": 30, "email": "alice@test.com"}, "Missing required field: name"),
        ({"name": 123, "age": 30, "email": "alice@test.com"}, "expected type <class 'str'>, got <class 'int'>"),
        ({"name": "Alice", "age": "thirty", "email": "alice@test.com"}, "expected type <class 'int'>, got <class 'str'>"),
    ])
    def test_schema_validation_failures(self, schema_validator, data, expected_error):
        """Test schema validation failures with different error types"""
        result = schema_validator.validate(data)
        assert result.is_valid is False
        assert len(result.errors) > 0
        # Verify the error message contains the expected error
        assert any(expected_error in err for err in result.errors)

    def test_empty_schema(self):
        """Test validation with empty schema"""
        validator = SchemaValidator({"schema": {}})
        data = {"anything": "goes"}
        result = validator.validate(data)
        assert result.is_valid is True
        
    def test_complex_nested_schema(self):
        """Test validation with nested schema"""
        schema = {
            "required": ["user", "settings"],
            "types": {
                "user": dict,
                "settings": dict
            }
        }
        validator = SchemaValidator({"schema": schema})
        
        # Valid nested data
        data = {
            "user": {"id": 1, "name": "Alice"},
            "settings": {"theme": "dark"}
        }
        result = validator.validate(data)
        assert result.is_valid is True
        
        # Invalid - missing required field
        data = {"user": {"id": 1, "name": "Alice"}}
        result = validator.validate(data)
        assert result.is_valid is False
        assert "Missing required field: settings" in result.errors[0]


# ============================================================
# TEST: SalesDataValidator
# ============================================================

class TestSalesDataValidator:
    """Test SalesDataValidator with comprehensive scenarios"""
    
    def test_valid_sales_data(self, valid_sales_df):
        """Test valid sales data"""
        result = validate_sales_data(valid_sales_df)
        assert result.is_valid is True
        assert len(result.errors) == 0

    @pytest.mark.parametrize("column_to_remove", [
        "product_id",
        "sales",
        "date"
    ])
    def test_missing_required_columns(self, valid_sales_df, column_to_remove):
        """Test validation with missing required columns"""
        df = valid_sales_df.drop(columns=[column_to_remove])
        result = validate_sales_data(df)
        assert result.is_valid is False
        assert f"Missing required column: {column_to_remove}" in result.errors[0]

    @pytest.mark.parametrize("sales_values,should_pass", [
        ([100, 200, 150], True),
        ([100, -50, 150], False),
        ([0, 100, 200], True),  # Zero is allowed
        ([-1, 0, 100], False),
        ([100, 200, None], False),
        ([100, 200, 150.5], True),  # Float allowed
    ])
    def test_sales_value_validation(self, valid_sales_df, sales_values, should_pass):
        """Test validation of sales values with various scenarios"""
        df = valid_sales_df.copy()
        df["sales"] = sales_values
        
        result = validate_sales_data(df)
        if should_pass:
            assert result.is_valid is True
        else:
            assert result.is_valid is False
            assert any("negative" in err.lower() or "null" in err.lower() for err in result.errors)

    def test_empty_dataframe(self):
        """Test validation with empty DataFrame"""
        df = pd.DataFrame()
        result = validate_sales_data(df)
        assert result.is_valid is False
        
    def test_null_product_ids(self, valid_sales_df):
        """Test validation with null product IDs"""
        df = valid_sales_df.copy()
        df.loc[0, "product_id"] = None
        result = validate_sales_data(df)
        assert result.is_valid is False
        assert "null product IDs" in result.errors[0].lower()

    @pytest.mark.parametrize("input_type", [
        pd.DataFrame,
        dict,
        list,
    ])
    def test_different_input_types(self, valid_sales_df, input_type):
        """Test validation with different input types"""
        if input_type == pd.DataFrame:
            data = valid_sales_df
        elif input_type == dict:
            data = valid_sales_df.iloc[0].to_dict()
        else:  # list
            data = valid_sales_df.to_dict('records')
        
        result = validate_sales_data(data)
        # Should handle dict/list by converting to DataFrame
        # Just validate it doesn't raise an exception
        assert isinstance(result, ValidationResult)

    def test_large_dataset_performance(self, benchmark):
        """Benchmark test for large dataset validation"""
        # Create large DataFrame
        data = pd.DataFrame({
            "product_id": list(range(10000)),
            "sales": np.random.randint(0, 1000, 10000),
            "date": pd.date_range("2024-01-01", periods=10000)
        })
        
        result = benchmark(validate_sales_data, data)
        assert result.is_valid is True


