class TestIntegrationWithMocks:
    """Integration tests with external dependencies mocked"""
    
    def test_validate_with_external_config(self):
        """Test validation with external configuration"""
        # Mock external config file
        with patch('builtins.open') as mock_open:
            mock_open.return_value.__enter__.return_value.read.return_value = json.dumps({
                "validators": [
                    {"type": "data_type", "expected_type": dict}
                ]
            })
            
            # Simulate loading config from external source
            import json
            config = json.loads('{"validators": [{"type": "data_type", "expected_type": "dict"}]}')
            
            # Fix the type (should be class, not string)
            config["validators"][0]["expected_type"] = dict
            
            validator = DataValidator(config)
            result = validator.validate({"test": "data"})
            
            assert result.is_valid is True


# ============================================================
# PERFORMANCE TESTS
# ============================================================

class TestPerformance:
    """Performance tests for validators"""
    
    def test_large_dataset_validation_speed(self, benchmark):
        """Benchmark: Validate large dataset should be fast"""
        data = pd.DataFrame({
            "product_id": list(range(10000)),
            "sales": np.random.randint(0, 1000, 10000),
            "date": pd.date_range("2024-01-01", periods=10000)
        })
        
        result = benchmark(validate_sales_data, data)
        assert result.is_valid is True
    
    def test_batch_validation_speed(self, benchmark):
        """Benchmark: Batch validate multiple DataFrames"""
        datasets = []
        for i in range(100):
            datasets.append(pd.DataFrame({
                "product_id": list(range(100)),
                "sales": np.random.randint(0, 1000, 100),
                "date": pd.date_range("2024-01-01", periods=100)
            }))
        
        def batch_validate():
            for df in datasets:
                validate_sales_data(df)
        
        benchmark(batch_validate)
        # Just ensure it runs without errors
        assert True