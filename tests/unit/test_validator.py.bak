class TestDemandForecastValidator:
    """Test DemandForecastValidator with comprehensive scenarios"""
    
    def test_valid_forecast(self, valid_forecast_df):
        """Test valid forecast data"""
        result = validate_forecast(valid_forecast_df)
        assert result.is_valid is True
        assert len(result.errors) == 0

    @pytest.mark.parametrize("column_to_remove", [
        "product_id",
        "forecast_date",
        "predicted_demand"
    ])
    def test_missing_required_columns(self, valid_forecast_df, column_to_remove):
        """Test forecast validation with missing required columns"""
        df = valid_forecast_df.drop(columns=[column_to_remove])
        result = validate_forecast(df)
        assert result.is_valid is False
        assert f"Missing required column: {column_to_remove}" in result.errors[0]

    @pytest.mark.parametrize("demand_values,should_pass", [
        ([80, 90, 85], True),
        ([80, -10, 85], False),
        ([0, 80, 90], True),  # Zero is allowed
        ([-1, 80, 90], False),
        ([80, 90, None], False),
        ([80, 90, 85.5], True),  # Float allowed
        ([80, 90, float('inf')], False),
        ([80, 90, float('nan')], False),
    ])
    def test_demand_value_validation(self, valid_forecast_df, demand_values, should_pass):
        """Test validation of demand values with various scenarios"""
        df = valid_forecast_df.copy()
        df["predicted_demand"] = demand_values
        
        result = validate_forecast(df)
        if should_pass:
            assert result.is_valid is True
        else:
            assert result.is_valid is False
            assert len(result.errors) > 0

    def test_invalid_date_formats(self, valid_forecast_df):
        """Test validation with invalid date formats"""
        df = valid_forecast_df.copy()
        df.loc[0, "forecast_date"] = "invalid-date"
        
        result = validate_forecast(df)
        assert result.is_valid is False
        assert any("forecast_date" in err.lower() for err in result.errors)


# ============================================================
# TEST: DataValidator (Orchestrator)
# ============================================================

class TestDataValidator:
    """Test DataValidator orchestrator with multiple validators"""
    
    def test_multiple_validators(self):
        """Test orchestrator with multiple validators"""
        config = {
            "validators": [
                {"type": "data_type", "expected_type": dict},
                {"type": "schema", "schema": {"required": ["name"], "types": {"name": str}}}
            ]
        }
        validator = DataValidator(config)
        
        # Valid data
        result = validator.validate({"name": "Alice"})
        assert result.is_valid is True
        assert len(result.errors) == 0
        
        # Invalid data
        result = validator.validate({"age": 30})
        assert result.is_valid is False
        assert len(result.errors) > 0

    def test_complex_orchestration(self, valid_sales_df):
        """Test orchestrator with complex validation chain"""
        config = {
            "validators": [
                {"type": "sales", "required_columns": ["product_id", "sales", "date"]},
                {"type": "schema", "schema": {"required": ["product_id", "sales"], "types": {"product_id": int, "sales": float}}}
            ]
        }
        validator = DataValidator(config)
        
        # Valid data
        result = validator.validate(valid_sales_df)
        assert result.is_valid is True
        
        # Invalid data
        invalid_df = valid_sales_df.copy()
        invalid_df["sales"] = -100  # Invalid sales value
        result = validator.validate(invalid_df)
        assert result.is_valid is False
        assert len(result.errors) > 0

    def test_validate_json_file(self):
        """Test validating JSON file"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as f:
            json.dump({"name": "Alice", "age": 30}, f)
            f.close()
            
            config = {
                "validators": [
                    {"type": "schema", "schema": {"required": ["name", "age"], "types": {"name": str, "age": int}}}
                ]
            }
            validator = DataValidator(config)
            result = validator.validate_file(f.name)
            
            assert result.is_valid is True
            
            # Clean up
            os.unlink(f.name)

    def test_validate_csv_file(self):
        """Test validating CSV file"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.csv', delete=False) as f:
            f.write("product_id,sales,date\n")
            f.write("1,100,2024-01-01\n")
            f.write("2,200,2024-01-02\n")
            f.write("3,150,2024-01-03\n")
            f.close()
            
            validator = DataValidator()
            result = validator.validate_file(f.name)
            
            assert result.is_valid is True
            
            # Clean up
            os.unlink(f.name)

    def test_validate_unsupported_file_type(self):
        """Test validating unsupported file type"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.txt', delete=False) as f:
            f.write("Some text data")
            f.close()
            
            validator = DataValidator()
            result = validator.validate_file(f.name)
            
            assert result.is_valid is False
            assert "Unsupported file type" in result.errors[0]
            
            # Clean up
            os.unlink(f.name)

    def test_validate_file_not_found(self):
        """Test validating non-existent file"""
        validator = DataValidator()
        result = validator.validate_file("/nonexistent/file.json")
        
        assert result.is_valid is False
        assert "File not found" in result.errors[0]

    def test_validate_malformed_json(self):
        """Test validating malformed JSON file"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as f:
            f.write("{malformed: json")
            f.close()
            
            validator = DataValidator()
            result = validator.validate_file(f.name)
            
            assert result.is_valid is False
            assert "Error reading file" in result.errors[0]
            
            # Clean up
            os.unlink(f.name)


# ============================================================
# TEST: ValidationResult
# ============================================================

def test_validation_result_creation():
    """Test ValidationResult dataclass"""
    result = ValidationResult(is_valid=True)
    assert result.is_valid is True
    assert len(result.errors) == 0
    assert len(result.warnings) == 0
    assert result.metadata == {}

def test_validation_result_with_errors():
    """Test ValidationResult with errors"""
    result = ValidationResult(
        is_valid=False,
        errors=["Error 1", "Error 2"],
        warnings=["Warning 1"],
        metadata={"source": "test"}
    )
    assert result.is_valid is False
    assert len(result.errors) == 2
    assert len(result.warnings) == 1
    assert result.metadata["source"] == "test"


